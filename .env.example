# 6-digit PIN the instructor uses to log into the dashboard (required)
INSTRUCTOR_PIN=123456

# Secret used to sign JWTs — use a long random string in production (required)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Port the server listens on (default: 3000)
PORT=3000

# Path to the SQLite database file
# On Railway/Render: point this at your persistent volume, e.g. /data/chat.db
DB_PATH=./data/chat.db
